{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "build:full": "tsc && cd ../frontend && npm run build && rm -rf ../backend/frontend/dist && mkdir -p ../backend/frontend && cp -r dist ../backend/frontend/dist",
    "start": "node dist/server.js",
    "collect": "tsx src/cron.ts --now",
    "cron": "tsx src/cron.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "AI News backend - collects trending AI content from GitHub, Anthropic, Google AI, and Hacker News",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.8",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
