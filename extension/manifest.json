{
  "manifest_version": 3,
  "name": "AI News - BuHu",
  "version": "1.1.0",
  "description": "Save articles to AI News dashboard, YouTube transcript & summary",
  "permissions": ["activeTab", "storage", "sidePanel", "tabs", "scripting"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
